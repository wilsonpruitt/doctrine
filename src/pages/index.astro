---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const documents = (await getCollection('documents'))
  .filter((d) => !d.data.draft)
  .sort((a, b) => a.data.order - b.data.order);

const ecumenical = documents.filter((d) => d.data.family === 'ecumenical');
const wesleyan = documents.filter((d) => d.data.family === 'wesleyan');
---

<Base
  title="Doctrine — Creeds & Confessions"
  description="An annotated reference for the Great Christian Tradition and the Wesleyan Tradition."
>
  <h1>Doctrine</h1>
  <p class="lede">
    An annotated reference for the Great Christian Tradition and the Wesleyan Tradition.
  </p>

  <p>
    The creed is the spine; each phrase is a door into translation history,
    controversy, interpretation across traditions, and pastoral use. A companion to
    <a href="https://difficult-passages.netlify.app">Difficult Passages</a>.
  </p>

  <h2>Ecumenical Creeds</h2>
  <ul class="doc-list">
    {ecumenical.map((d) => (
      <li>
        <a class="doc-title" href={`/creeds/${d.data.slug}`}>{d.data.title}</a>
        {d.data.subtitle && <span class="doc-subtitle">{d.data.subtitle}</span>}
        <div class="doc-date">{d.data.date}</div>
        <p class="doc-summary">{d.data.summary}</p>
      </li>
    ))}
  </ul>

  <h2>Wesleyan Tradition</h2>
  {wesleyan.length === 0 ? (
    <p><em>Coming soon: Wesley's General Rules (1743) and the Articles of Religion (1784).</em></p>
  ) : (
    <ul class="doc-list">
      {wesleyan.map((d) => (
        <li>
          <a class="doc-title" href={`/wesleyan/${d.data.slug}`}>{d.data.title}</a>
          <div class="doc-date">{d.data.date}</div>
          <p class="doc-summary">{d.data.summary}</p>
        </li>
      ))}
    </ul>
  )}
</Base>
