---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';

export async function getStaticPaths() {
  const docs = await getCollection('documents', (d) => d.data.family === 'wesleyan');
  const wesleyanSlugs = new Set(docs.map((d) => d.data.slug));
  const annotations = await getCollection(
    'annotations',
    (a) => !a.data.draft && wesleyanSlugs.has(a.data.document),
  );
  return annotations.map((a) => {
    const siblings = annotations
      .filter((b) => b.data.document === a.data.document)
      .sort((x, y) => x.data.order - y.data.order);
    const idx = siblings.findIndex((b) => b.data.phrase_slug === a.data.phrase_slug);
    return {
      params: { slug: a.data.document, phrase: a.data.phrase_slug },
      props: {
        annotation: a,
        doc: docs.find((d) => d.data.slug === a.data.document)!,
        siblings,
        prev: idx > 0 ? siblings[idx - 1] : null,
        next: idx < siblings.length - 1 ? siblings[idx + 1] : null,
      },
    };
  });
}

const { annotation, doc, siblings, prev, next } = Astro.props;
const { Content, headings } = await render(annotation);
const f = annotation.data;

// Resolve a related ref's URL prefix by the *target* document's family, so a
// General Rules annotation can cross-reference an ecumenical creed correctly.
const allDocs = await getCollection('documents');
const familyOf = new Map(allDocs.map((d) => [d.data.slug, d.data.family]));
function hrefFor(docSlug: string, phraseSlug: string) {
  const fam = familyOf.get(docSlug);
  const base = fam === 'wesleyan' ? 'wesleyan' : 'creeds';
  return `/${base}/${docSlug}/${phraseSlug}`;
}

// Only h2/h3 — h1 is the phrase title rendered above the body
const navHeadings = headings.filter((h) => h.depth === 2);

const contestedLabel: Record<typeof f.contested, string> = {
  high: 'highly contested',
  medium: 'moderately contested',
  low: 'well-settled',
};
---

<Base
  title={`${f.phrase_display} — ${doc.data.title}`}
  description={`Annotation on "${f.phrase_display}" in ${doc.data.title}.`}
  wide
>
  <div class="annotation-layout">
    <article class="annotation-main">
      <p class="crumbs">
        <a href="/">Doctrine</a> · <a href={`/wesleyan/${doc.data.slug}`}>{doc.data.title}</a>
      </p>
      <h1>{f.phrase_display}</h1>

      <p class="contested-line">
        <span class={`contested-pill c-${f.contested}`}>{contestedLabel[f.contested]}</span>
      </p>

      {f.abstract && (
        <section class="abstract" aria-label="In brief">
          <p class="abstract-label">What it says</p>
          <p class="gloss">{`“`}{f.abstract.gloss}{`”`}</p>
          <dl class="beats">
            <dt>The stake</dt>
            <dd>{f.abstract.stake}</dd>
            <dt>Why it matters</dt>
            <dd>{f.abstract.matters}</dd>
            <dt>The Wesleyan take</dt>
            <dd>{f.abstract.wesleyan}</dd>
          </dl>
        </section>
      )}

      {(f.latin || f.greek || f.original_english) && (
        <dl class="source-block">
          {f.latin && (
            <>
              <dt>Latin</dt>
              <dd>
                <em>{f.latin}</em>
                {f.latin_note && <span class="note">{f.latin_note}</span>}
                {f.latin_variants && f.latin_variants.map((v) => (
                  <span class="note">variant: <em>{v.text}</em>{v.note ? ` — ${v.note}` : ''}</span>
                ))}
              </dd>
            </>
          )}
          {f.greek && (
            <>
              <dt>Greek</dt>
              <dd>
                <em>{f.greek}</em>
                {f.greek_note && <span class="note">{f.greek_note}</span>}
                {f.greek_variants && f.greek_variants.map((v) => (
                  <span class="note">variant: <em>{v.text}</em>{v.note ? ` — ${v.note}` : ''}</span>
                ))}
              </dd>
            </>
          )}
          {f.original_english && (
            <>
              <dt>Original English</dt>
              <dd>
                <em>{f.original_english}</em>
                {f.original_english_note && <span class="note">{f.original_english_note}</span>}
              </dd>
            </>
          )}
        </dl>
      )}

      <table class="translations">
        <thead>
          <tr><th>Version</th><th>Rendering</th></tr>
        </thead>
        <tbody>
          {f.translations.map((t) => (
            <tr>
              <th scope="row">{t.version}</th>
              <td>
                {t.text}
                {t.note && <span class="note">{t.note}</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>

      {f.traditions.length > 0 && (
        <p class="traditions-line">
          <span class="meta-label">Traditions cited</span>
          {f.traditions.map((t, i) => (
            <>
              {i > 0 && <span class="dot">·</span>}
              <span class="tradition">{t.replace(/_/g, ' ')}</span>
            </>
          ))}
        </p>
      )}

      <div class="annotation-body">
        <Content />
      </div>

      {f.related.length > 0 && (
        <section class="related">
          <h3>Related</h3>
          <ul>
            {f.related.map((r) => {
              const [docSlug, phraseSlug] = r.split('/');
              return (
                <li>
                  <a href={hrefFor(docSlug, phraseSlug)}>
                    {docSlug} — {phraseSlug.replace(/-/g, ' ')}
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      )}

      <nav class="prev-next" aria-label="Adjacent phrases">
        <div class="prev-next-cell prev-cell">
          {prev && (
            <a href={`/wesleyan/${doc.data.slug}/${prev.data.phrase_slug}`}>
              <span class="arrow">←</span>
              <span class="label">Previous</span>
              <span class="phrase">{prev.data.phrase_display}</span>
            </a>
          )}
        </div>
        <div class="prev-next-cell next-cell">
          {next && (
            <a href={`/wesleyan/${doc.data.slug}/${next.data.phrase_slug}`}>
              <span class="label">Next</span>
              <span class="phrase">{next.data.phrase_display}</span>
              <span class="arrow">→</span>
            </a>
          )}
        </div>
      </nav>
    </article>

    {navHeadings.length > 1 && (
      <aside class="annotation-toc" aria-label="Sections">
        <p class="toc-label">On this page</p>
        <ol>
          {navHeadings.map((h) => (
            <li><a href={`#${h.slug}`}>{h.text}</a></li>
          ))}
        </ol>
        <p class="toc-foot">
          <a href={`/wesleyan/${doc.data.slug}`}>← Back to spine</a>
        </p>
      </aside>
    )}
  </div>

  <section class="inline-creed" aria-label="The full document">
    <p class="inline-creed-label">{doc.data.title}</p>
    <p class="inline-creed-text">
      {siblings.map((s, i) => (
        <>
          {s.data.phrase_slug === f.phrase_slug ? (
            <span class={`phrase c-${s.data.contested} current`}>{s.data.phrase_display}</span>
          ) : (
            <a
              class={`phrase c-${s.data.contested}`}
              href={`/wesleyan/${doc.data.slug}/${s.data.phrase_slug}`}
            >{s.data.phrase_display}</a>
          )}{i < siblings.length - 1 ? ' ' : ''}
        </>
      ))}
    </p>
  </section>
</Base>
