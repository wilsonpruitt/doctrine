---
import { UI, type Locale } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  locale?: Locale;
  translationStatus?: 'source' | 'machine-draft' | 'native-reviewed';
}
const {
  title,
  description,
  wide = false,
  locale = 'en',
  translationStatus = 'source',
} = Astro.props;
const isTranslation = locale !== 'en';
const ui = UI[locale] ?? UI.en;
const base = locale === 'en' ? '' : `/${locale}`;
const homeHref = base || '/';
const aboutHref = `${base}/about`;
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <nav class="topnav">
      <a href={homeHref} class="brand">{ui.brand}</a>
      <span class="navlinks">
        <a href={homeHref}>{ui.navCreeds}</a>
        <a href={aboutHref}>{ui.navAbout}</a>
      </span>
    </nav>
    {isTranslation && (
      <p class={`xl-banner${translationStatus === 'native-reviewed' ? ' reviewed' : ''}`}>
        {translationStatus === 'native-reviewed' ? ui.bannerReviewed : ui.bannerDraft}
      </p>
    )}
    <main class={wide ? 'wide' : 'prose'}>
      <slot />
    </main>
    <footer>
      <p>
        {ui.footer.lead}
        <a href="https://difficult-passages.netlify.app">{ui.footer.difficultPassages}</a>.
      </p>
    </footer>
  </body>
</html>
