---
import { UI, type Locale } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  locale?: Locale;
  translationStatus?: 'source' | 'machine-draft' | 'native-reviewed';
  // On an English page: the Spanish counterpart to link to. Routes pass the
  // exact translated URL when it exists; omitted → falls back to the Spanish
  // home so the switcher never 404s on an untranslated page.
  esHref?: string;
}
const {
  title,
  description,
  wide = false,
  locale = 'en',
  translationStatus = 'source',
  esHref,
} = Astro.props;
const isTranslation = locale !== 'en';
const ui = UI[locale] ?? UI.en;
const base = locale === 'en' ? '' : `/${locale}`;
const homeHref = base || '/';
const aboutHref = `${base}/about`;

// Language switcher. English is the complete superset, so on a translated
// page the English counterpart is always the same path minus the locale
// prefix. On an English page we link to the route-supplied Spanish URL, or
// the Spanish home if this page has no translation yet.
const switchHref = isTranslation
  ? Astro.url.pathname.slice(`/${locale}`.length) || '/'
  : esHref ?? '/es/';
const switchLabel = isTranslation ? 'English' : 'Español';
const switchHrefLang = isTranslation ? 'en' : 'es';
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <nav class="topnav">
      <a href={homeHref} class="brand">{ui.brand}</a>
      <span class="navlinks">
        <a href={homeHref}>{ui.navCreeds}</a>
        <a href={aboutHref}>{ui.navAbout}</a>
        <a class="lang-switch" href={switchHref} hreflang={switchHrefLang} lang={switchHrefLang}>{switchLabel}</a>
      </span>
    </nav>
    {isTranslation && (
      <p class={`xl-banner${translationStatus === 'native-reviewed' ? ' reviewed' : ''}`}>
        {translationStatus === 'native-reviewed' ? ui.bannerReviewed : ui.bannerDraft}
      </p>
    )}
    <main class={wide ? 'wide' : 'prose'}>
      <slot />
    </main>
    <footer>
      <p>
        {ui.footer.lead}
        <a href="https://difficult-passages.netlify.app">{ui.footer.difficultPassages}</a>.
      </p>
    </footer>
  </body>
</html>
