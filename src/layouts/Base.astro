---
interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  locale?: string;
  translationStatus?: 'source' | 'machine-draft' | 'native-reviewed';
}
const {
  title,
  description,
  wide = false,
  locale = 'en',
  translationStatus = 'source',
} = Astro.props;
const isTranslation = locale !== 'en';
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <nav class="topnav">
      <a href="/" class="brand">Doctrine</a>
      <span class="navlinks">
        <a href="/">Creeds</a>
        <a href="/about">About</a>
      </span>
    </nav>
    {isTranslation && (
      <p class={`xl-banner${translationStatus === 'native-reviewed' ? ' reviewed' : ''}`}>
        {translationStatus === 'native-reviewed'
          ? 'Translation reviewed by a native speaker. The English remains the authoritative text.'
          : 'Machine-assisted translation, pending review by a native speaker. The English is the authoritative text.'}
      </p>
    )}
    <main class={wide ? 'wide' : 'prose'}>
      <slot />
    </main>
    <footer>
      <p>
        A Wroot Press reference companion to
        <a href="https://difficult-passages.netlify.app">Difficult Passages</a>.
      </p>
    </footer>
  </body>
</html>
